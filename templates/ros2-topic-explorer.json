{
  "kind": "blacknode.workflow",
  "schema_version": 1,
  "name": "ROS 2 Live Roundtrip Demo",
  "saved_at": "2026-06-12T00:00:00",
  "entrypoint": {
    "node_id": "dashboard",
    "port": "dashboard"
  },
  "metadata": {
    "template": true,
    "description": "Visual end-to-end ROS 2 test. Press Run to render a pass/fail dashboard showing the publisher-to-topic-to-echo message path, backend, discovery, and graph metrics.",
    "color": "#2e9fe6",
    "required_packages": ["blacknode-ros2"]
  },
  "node_meta": {
    "check": {
      "id": "check",
      "type": "ROS2SystemCheck",
      "params": {
        "refresh": true
      },
      "pos": [40, 340],
      "inputs": ["refresh"],
      "outputs": ["available", "backend", "report"],
      "input_types": {
        "refresh": "Bool"
      },
      "output_types": {
        "available": "Bool",
        "backend": "Text",
        "report": "Text"
      },
      "input_defaults": {
        "refresh": true
      }
    },
    "demo_pub": {
      "id": "demo_pub",
      "type": "ROS2DemoPublisher",
      "params": {
        "action": "start",
        "topic": "/blacknode_demo",
        "message": "Blacknode ROS 2 roundtrip works",
        "rate": 5.0
      },
      "pos": [360, 340],
      "inputs": ["trigger", "action", "topic", "message", "rate"],
      "outputs": ["report"],
      "input_types": {
        "trigger": "Any",
        "action": "Text",
        "topic": "Text",
        "message": "Text",
        "rate": "Float"
      },
      "output_types": {
        "report": "Text"
      },
      "input_defaults": {
        "action": "start",
        "topic": "/blacknode_demo",
        "message": "Blacknode ROS 2 roundtrip works",
        "rate": 5.0
      }
    },
    "echo": {
      "id": "echo",
      "type": "ROS2TopicEcho",
      "params": {
        "topic": "/blacknode_demo",
        "msg_type": "std_msgs/msg/String",
        "count": 1,
        "timeout": 20.0
      },
      "pos": [700, 40],
      "inputs": ["trigger", "topic", "msg_type", "count", "timeout"],
      "outputs": ["messages", "report"],
      "input_types": {
        "trigger": "Any",
        "topic": "Text",
        "msg_type": "Text",
        "count": "Int",
        "timeout": "Float"
      },
      "output_types": {
        "messages": "List",
        "report": "Text"
      },
      "input_defaults": {
        "topic": "/blacknode_demo",
        "msg_type": "std_msgs/msg/String",
        "count": 1,
        "timeout": 20.0
      }
    },
    "topics": {
      "id": "topics",
      "type": "ROS2TopicList",
      "params": {
        "show_types": true
      },
      "pos": [700, 220],
      "inputs": ["trigger", "show_types"],
      "outputs": ["topics", "report"],
      "input_types": {
        "trigger": "Any",
        "show_types": "Bool"
      },
      "output_types": {
        "topics": "List",
        "report": "Text"
      },
      "input_defaults": {
        "show_types": true
      }
    },
    "nodes": {
      "id": "nodes",
      "type": "ROS2NodeList",
      "params": {},
      "pos": [700, 400],
      "inputs": ["trigger"],
      "outputs": ["nodes", "report"],
      "input_types": {
        "trigger": "Any"
      },
      "output_types": {
        "nodes": "List",
        "report": "Text"
      },
      "input_defaults": {}
    },
    "services": {
      "id": "services",
      "type": "ROS2ServiceList",
      "params": {
        "show_types": true
      },
      "pos": [700, 580],
      "inputs": ["trigger", "show_types"],
      "outputs": ["services", "report"],
      "input_types": {
        "trigger": "Any",
        "show_types": "Bool"
      },
      "output_types": {
        "services": "List",
        "report": "Text"
      },
      "input_defaults": {
        "show_types": true
      }
    },
    "interface": {
      "id": "interface",
      "type": "ROS2InterfaceShow",
      "params": {
        "interface": "std_msgs/msg/String"
      },
      "pos": [700, 760],
      "inputs": ["trigger", "interface"],
      "outputs": ["definition", "report"],
      "input_types": {
        "trigger": "Any",
        "interface": "Text"
      },
      "output_types": {
        "definition": "Text",
        "report": "Text"
      },
      "input_defaults": {
        "interface": "std_msgs/msg/String"
      }
    },
    "dashboard": {
      "id": "dashboard",
      "type": "ROS2VisualDashboard",
      "params": {
        "label": "ROS 2 visual test dashboard",
        "expected_topic": "/blacknode_demo",
        "expected_message": "Blacknode ROS 2 roundtrip works"
      },
      "pos": [1080, 160],
      "inputs": [
        "status",
        "publisher",
        "echo_report",
        "messages",
        "topics",
        "nodes",
        "services",
        "definition",
        "expected_topic",
        "expected_message"
      ],
      "outputs": ["dashboard", "passed", "summary"],
      "input_types": {
        "status": "Text",
        "publisher": "Text",
        "echo_report": "Text",
        "messages": "List",
        "topics": "List",
        "nodes": "List",
        "services": "List",
        "definition": "Text",
        "expected_topic": "Text",
        "expected_message": "Text"
      },
      "output_types": {
        "dashboard": "Image",
        "passed": "Bool",
        "summary": "Dict"
      },
      "input_defaults": {
        "expected_topic": "/blacknode_demo",
        "expected_message": "Blacknode ROS 2 roundtrip works"
      }
    }
  },
  "edges": [
    {
      "from": "check",
      "from_port": "report",
      "to": "demo_pub",
      "to_port": "trigger"
    },
    {
      "from": "check",
      "from_port": "report",
      "to": "dashboard",
      "to_port": "status"
    },
    {
