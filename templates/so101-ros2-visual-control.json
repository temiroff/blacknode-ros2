        "shoulder_lift": -20.0,
        "elbow_flex": 35.0,
        "wrist_flex": 15.0,
        "wrist_roll": 0.0,
        "gripper": 25.0
      },
      "pos": [920, 120],
      "inputs": [
        "bridge",
        "shoulder_pan",
        "shoulder_lift",
        "elbow_flex",
        "wrist_flex",
        "wrist_roll",
        "gripper"
