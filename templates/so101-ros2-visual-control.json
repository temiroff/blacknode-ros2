        "robot_id": "my_so101",
        "camera_index": 0,
        "camera_name": "front",
        "max_relative_target": 5.0,
        "motion_enabled": false
      },
      "pos": [40, 120],
      "inputs": [
        "serial_port",
        "robot_id",
        "camera_index",
        "camera_name",
        "max_relative_target",
        "motion_enabled"
