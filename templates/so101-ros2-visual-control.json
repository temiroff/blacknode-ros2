      "outputs": ["preview", "command", "payload"],
      "input_types": {
        "bridge": "Dict",
        "shoulder_pan": "Float",
        "shoulder_lift": "Float",
        "elbow_flex": "Float",
        "wrist_flex": "Float",
        "wrist_roll": "Float",
        "gripper": "Float"
      },
      "output_types": {
        "preview": "Image",
        "command": "Dict",
        "payload": "Text"
