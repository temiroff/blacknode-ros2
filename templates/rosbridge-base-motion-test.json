{
  "kind": "blacknode.workflow",
  "schema_version": 1,
  "name": "Rosbridge Base Motion Test",
  "saved_at": "2026-07-19T00:00:00",
  "entrypoint": {
    "node_id": "odom",
    "port": "report"
  },
  "metadata": {
    "template": true,
    "description": "Safety-gated first drive for any mobile base reachable over rosbridge: LiDAR clearance check, disarmed BaseSafetyGate, one bounded 0.1 m/s forward move, an explicit stop, and an odometry readback. Replace ROBOT_IP on every node and set cmd_vel/scan/odom topics to match your robot (defaults are the ROS conventions). The gate ships DISARMED: put the robot on the floor with 1 m of clear space (or on a stand with the wheels free), then set armed=true on the BaseSafetyGate node and run again.",
    "color": "#2e9fe6",
    "required_packages": ["blacknode-ros2"]
  },
  "node_meta": {
    "scan": {
      "id": "scan",
      "type": "ROS2LaserScanCheck",
      "params": {
        "host": "ROBOT_IP",
        "port": 9090,
        "scan_topic": "/scan",
        "sector_deg": 60.0,
        "min_clearance_m": 0.4,
        "timeout": 6.0
      },
      "pos": [40, 200],
      "inputs": ["trigger", "host", "port", "scan_topic", "sector_deg", "min_clearance_m", "timeout"],
      "outputs": ["clearance_m", "clear", "samples", "report"],
      "input_types": {
        "trigger": "Any",
        "host": "Text",
        "port": "Int",
        "scan_topic": "Text",
        "sector_deg": "Float",
        "min_clearance_m": "Float",
        "timeout": "Float"
      },
      "output_types": {
        "clearance_m": "Float",
        "clear": "Bool",
        "samples": "Int",
        "report": "Text"
      },
      "input_defaults": {
        "host": "ROBOT_IP",
        "port": 9090,
        "scan_topic": "/scan",
        "sector_deg": 60.0,
        "min_clearance_m": 0.4,
        "timeout": 6.0
      }
    },
    "gate": {
      "id": "gate",
      "type": "BaseSafetyGate",
      "params": {
        "armed": false,
        "max_speed_mps": 0.15,
        "max_turn_rps": 0.5,
        "max_duration_s": 1.5,
        "min_clearance_m": 0.4,
        "require_clearance": true,
        "emergency_stop": false
      },
      "pos": [420, 200],
      "inputs": ["armed", "max_speed_mps", "max_turn_rps", "max_duration_s", "min_clearance_m", "clearance_m", "require_clearance", "emergency_stop"],
      "outputs": ["authorization", "authorized", "report"],
      "input_types": {
        "armed": "Bool",
        "max_speed_mps": "Float",
        "max_turn_rps": "Float",
        "max_duration_s": "Float",
        "min_clearance_m": "Float",
        "clearance_m": "Float",
        "require_clearance": "Bool",
        "emergency_stop": "Bool"
      },
      "output_types": {
        "authorization": "Dict",
        "authorized": "Bool",
        "report": "Text"
      },
      "input_defaults": {
        "armed": false,
        "max_speed_mps": 0.15,
        "max_turn_rps": 0.5,
        "max_duration_s": 1.5,
        "min_clearance_m": 0.4,
        "require_clearance": true,
        "emergency_stop": false
      }
    },
    "move": {
      "id": "move",
      "type": "ROS2BaseMove",
      "params": {
        "host": "ROBOT_IP",
        "port": 9090,
        "cmd_vel_topic": "/cmd_vel",
        "vx": 0.1,
        "vy": 0.0,
        "wz": 0.0,
        "duration_s": 1.0,
        "rate_hz": 10.0,
        "timeout": 10.0
      },
      "pos": [800, 200],
      "inputs": ["authorization", "host", "port", "cmd_vel_topic", "vx", "vy", "wz", "duration_s", "rate_hz", "timeout"],
      "outputs": ["moved", "command", "report"],
      "input_types": {
        "authorization": "Dict",
        "host": "Text",
        "port": "Int",
        "cmd_vel_topic": "Text",
        "vx": "Float",
        "vy": "Float",
        "wz": "Float",
        "duration_s": "Float",
        "rate_hz": "Float",
        "timeout": "Float"
      },
      "output_types": {
        "moved": "Bool",
        "command": "Dict",
        "report": "Text"
      },
      "input_defaults": {
        "host": "ROBOT_IP",
        "port": 9090,
        "cmd_vel_topic": "/cmd_vel",
        "vx": 0.1,
        "vy": 0.0,
        "wz": 0.0,
        "duration_s": 1.0,
        "rate_hz": 10.0,
        "timeout": 10.0
      }
    },
    "stop": {
      "id": "stop",
      "type": "ROS2BaseStop",
      "params": {
        "host": "ROBOT_IP",
        "port": 9090,
        "cmd_vel_topic": "/cmd_vel",
        "timeout": 5.0
      },
      "pos": [1180, 200],
      "inputs": ["trigger", "host", "port", "cmd_vel_topic", "timeout"],
      "outputs": ["stopped", "report"],
      "input_types": {
        "trigger": "Any",
        "host": "Text",
        "port": "Int",
        "cmd_vel_topic": "Text",
        "timeout": "Float"
      },
      "output_types": {
        "stopped": "Bool",
        "report": "Text"
      },
      "input_defaults": {
        "host": "ROBOT_IP",
        "port": 9090,
        "cmd_vel_topic": "/cmd_vel",
        "timeout": 5.0
      }
    },
    "odom": {
      "id": "odom",
      "type": "ROS2OdomState",
      "params": {
        "host": "ROBOT_IP",
        "port": 9090,
        "odom_topic": "/odom",
        "timeout": 5.0
      },
      "pos": [1560, 200],
      "inputs": ["trigger", "host", "port", "odom_topic", "timeout"],
      "outputs": ["position", "velocity", "report"],
      "input_types": {
        "trigger": "Any",
        "host": "Text",
        "port": "Int",
        "odom_topic": "Text",
        "timeout": "Float"
      },
      "output_types": {
        "position": "Dict",
        "velocity": "Dict",
        "report": "Text"
      },
      "input_defaults": {
        "host": "ROBOT_IP",
        "port": 9090,
        "odom_topic": "/odom",
        "timeout": 5.0
      }
    }
  },
  "edges": [
    {
      "from": "scan",
      "from_port": "clearance_m",
      "to": "gate",
      "to_port": "clearance_m"
    },
    {
      "from": "gate",
      "from_port": "authorization",
      "to": "move",
      "to_port": "authorization"
    },
    {
      "from": "move",
      "from_port": "report",
      "to": "stop",
      "to_port": "trigger"
    },
    {
      "from": "stop",
      "from_port": "report",
      "to": "odom",
      "to_port": "trigger"
    }
  ]
}
