{
  "kind": "blacknode.workflow",
  "schema_version": 1,
  "name": "Publish & Subscribe Messages",
  "saved_at": "2026-07-21T00:00:00",
  "entrypoint": {
    "node_id": "dashboard",
    "port": "dashboard"
  },
  "metadata": {
    "template": true,
    "description": "Shows ROS 2 messaging working end to end. Press Run: it publishes messages on /blacknode_demo, subscribes and reads one back, lists what is live on the graph, and draws a green PASS dashboard when the round trip succeeded. Nothing to set up first — it starts Docker and the publisher itself. Change the message text on the publisher node and run again to see your own text come back.",
    "color": "#2e9fe6",
    "required_packages": ["blacknode-ros2"],
    "required_components": [
      "blacknode-ros2/core",
      "blacknode-ros2/topics",
      "blacknode-ros2/services",
      "blacknode-ros2/diagnostics"
    ]
  },
  "node_meta": {
    "check": {
      "id": "check",
      "type": "ROS2SystemCheck",
      "params": {"refresh": true},
      "pos": [40, 340],
      "inputs": ["refresh"],
      "outputs": ["available", "backend", "report"],
      "input_types": {"refresh": "Bool"},
      "output_types": {"available": "Bool", "backend": "Text", "report": "Text"},
      "input_defaults": {"refresh": true}
    },
    "publisher": {
      "id": "publisher",
      "type": "ROS2TopicPublisher",
      "params": {
        "action": "start",
        "topic": "/blacknode_demo",
        "msg_type": "std_msgs/msg/String",
        "payload": "data: Blacknode ROS 2 roundtrip works",
        "rate_hz": 5.0
      },
      "pos": [360, 340],
      "inputs": ["trigger", "action", "topic", "msg_type", "payload", "rate_hz"],
      "outputs": ["running", "backend", "report"],
      "input_types": {
        "trigger": "Any",
        "action": "Text",
        "topic": "Text",
        "msg_type": "Text",
        "payload": "Text",
        "rate_hz": "Float"
      },
      "output_types": {
        "running": "Bool",
        "backend": "Text",
        "report": "Text"
      },
      "input_defaults": {
        "action": "start",
        "topic": "/blacknode_demo",
        "msg_type": "std_msgs/msg/String",
        "payload": "data: Blacknode ROS 2 roundtrip works",
        "rate_hz": 5.0
      },
      "input_choices": {"action": ["start", "stop"]}
    },
    "subscriber": {
      "id": "subscriber",
      "type": "ROS2TopicEcho",
      "params": {
        "topic": "/blacknode_demo",
        "msg_type": "std_msgs/msg/String",
        "count": 1,
        "timeout": 20.0
      },
      "pos": [720, 40],
      "inputs": ["trigger", "topic", "msg_type", "count", "timeout"],
      "outputs": ["messages", "report"],
      "input_types": {
        "trigger": "Any",
        "topic": "Text",
        "msg_type": "Text",
        "count": "Int",
        "timeout": "Float"
      },
      "output_types": {"messages": "List", "report": "Text"},
      "input_defaults": {
        "topic": "/blacknode_demo",
        "msg_type": "std_msgs/msg/String",
        "count": 1,
        "timeout": 20.0
      }
    },
    "topics": {
      "id": "topics",
      "type": "ROS2TopicList",
      "params": {"show_types": true},
      "pos": [720, 240],
      "inputs": ["trigger", "show_types"],
      "outputs": ["topics", "report"],
      "input_types": {"trigger": "Any", "show_types": "Bool"},
      "output_types": {"topics": "List", "report": "Text"},
      "input_defaults": {"show_types": true}
    },
    "nodes": {
      "id": "nodes",
      "type": "ROS2NodeList",
      "params": {},
      "pos": [720, 440],
      "inputs": ["trigger"],
      "outputs": ["nodes", "report"],
      "input_types": {"trigger": "Any"},
      "output_types": {"nodes": "List", "report": "Text"},
      "input_defaults": {}
    },
    "services": {
      "id": "services",
      "type": "ROS2ServiceList",
      "params": {"show_types": true},
      "pos": [720, 640],
      "inputs": ["trigger", "show_types"],
      "outputs": ["services", "report"],
      "input_types": {"trigger": "Any", "show_types": "Bool"},
      "output_types": {"services": "List", "report": "Text"},
      "input_defaults": {"show_types": true}
    },
    "interface": {
      "id": "interface",
      "type": "ROS2InterfaceShow",
      "params": {"interface": "std_msgs/msg/String"},
      "pos": [720, 840],
      "inputs": ["trigger", "interface"],
      "outputs": ["definition", "report"],
      "input_types": {"trigger": "Any", "interface": "Text"},
      "output_types": {"definition": "Text", "report": "Text"},
      "input_defaults": {"interface": "std_msgs/msg/String"}
    },
    "dashboard": {
      "id": "dashboard",
      "type": "ROS2VisualDashboard",
      "params": {
        "expected_topic": "/blacknode_demo",
        "expected_message": "Blacknode ROS 2 roundtrip works"
      },
      "pos": [1120, 240],
      "inputs": [
        "status",
        "publisher",
        "echo_report",
        "messages",
        "topics",
        "nodes",
        "services",
        "definition",
        "expected_topic",
        "expected_message"
      ],
      "outputs": ["dashboard", "passed", "summary"],
      "input_types": {
        "status": "Text",
        "publisher": "Text",
        "echo_report": "Text",
        "messages": "List",
        "topics": "List",
        "nodes": "List",
        "services": "List",
        "definition": "Text",
        "expected_topic": "Text",
        "expected_message": "Text"
      },
      "output_types": {
        "dashboard": "Image",
        "passed": "Bool",
        "summary": "Dict"
      },
      "input_defaults": {
        "expected_topic": "/blacknode_demo",
        "expected_message": "Blacknode ROS 2 roundtrip works"
      }
    },
    "message_out": {
      "id": "message_out",
      "type": "Output",
      "params": {"label": "message received back"},
      "pos": [1120, 40],
      "inputs": ["value"],
      "outputs": [],
      "input_types": {"value": "Any"},
      "output_types": {},
      "input_defaults": {}
    }
  },
  "edges": [
    {"from": "check", "from_port": "report", "to": "publisher", "to_port": "trigger"},
    {"from": "check", "from_port": "report", "to": "dashboard", "to_port": "status"},
    {"from": "publisher", "from_port": "report", "to": "subscriber", "to_port": "trigger"},
    {"from": "publisher", "from_port": "report", "to": "topics", "to_port": "trigger"},
    {"from": "publisher", "from_port": "report", "to": "nodes", "to_port": "trigger"},
    {"from": "publisher", "from_port": "report", "to": "services", "to_port": "trigger"},
    {"from": "publisher", "from_port": "report", "to": "interface", "to_port": "trigger"},
    {"from": "publisher", "from_port": "report", "to": "dashboard", "to_port": "publisher"},
    {"from": "subscriber", "from_port": "messages", "to": "dashboard", "to_port": "messages"},
    {"from": "subscriber", "from_port": "messages", "to": "message_out", "to_port": "value"},
    {"from": "subscriber", "from_port": "report", "to": "dashboard", "to_port": "echo_report"},
    {"from": "topics", "from_port": "topics", "to": "dashboard", "to_port": "topics"},
    {"from": "nodes", "from_port": "nodes", "to": "dashboard", "to_port": "nodes"},
    {"from": "services", "from_port": "services", "to": "dashboard", "to_port": "services"},
    {"from": "interface", "from_port": "definition", "to": "dashboard", "to_port": "definition"}
  ]
}
